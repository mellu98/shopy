{
  "name": "shopify-theme-builder",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "dev": "shopify app dev",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && remix vite:build && remix-serve ./build/server/index.js",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "setup": "prisma generate && prisma migrate deploy",
    "db:migrate": "prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@remix-run/node": "^2.7.1",
    "@remix-run/react": "^2.7.1",
    "@remix-run/serve": "^2.7.1",
    "@shopify/app-bridge-react": "^4.1.2",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-api": "^11.4.1",
    "@shopify/shopify-app-remix": "^3.3.2",
    "@shopify/shopify-app-session-storage-prisma": "^5.2.3",
    "isbot": "^5.1.0",
    "prisma": "^5.19.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-tsconfig-paths": "^4.3.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.7.1",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "typescript": "^5.2.2",
    "vite": "^5.1.3"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "author": "theme-builder",
  "engines": {
    "node": ">=18.0.0"
  }
}
