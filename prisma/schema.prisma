generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model WizardState {
  id        String   @id @default("default")
  shop      String   @unique
  step      Int      @default(1)
  config    String   // JSON blob of MerchantConfig
  copyInput String?  // JSON blob of CopyGenerationInput
  copyGenerated Boolean @default(false)
  updatedAt DateTime @updatedAt
}

model GeneratedTheme {
  id          String   @id @default(cuid())
  shop        String
  themeName   String
  shopifyThemeId BigInt?
  config      String   // JSON blob of MerchantConfig
  status      String   @default("pending") // pending, generating, uploading, completed, failed
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
